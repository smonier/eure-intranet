[ euint:dashboardCard ] > jnt:content, jmix:editorialContent, euimix:component, euimix:queryContent
 - jcr:title (string) i18n
 - eui:type (string) = 'info' autocreated < 'info', 'stat', 'task', 'link'
 - eui:deeplink (string)
 - eui:value (string)
 - eui:icon (string, choicelist[resourceBundle]) < 'badgeuse', 'absences', 'conges', 'planning', 'annuaire', 'salles', 'messagerie', 'formation', 'ged', 'organigramme', 'frais', 'paie', 'dsi', 'securite', 'sante', 'calendar', 'news', 'it', 'learning', 'career', 'people', 'ideas', 'explore', 'accueil', 'agents', 'voirie', 'recherche'
