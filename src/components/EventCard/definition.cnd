[ euint:event ] > jnt:content, jmix:editorialContent, jmix:mainResource, euimix:component, euimix:queryContent, seumix:linkTo, jmix:tagged, jmix:categorized
 - jcr:title (string) i18n
 - eui:summary (string) i18n
 - eui:start (date)
 - eui:end (date)
 - eui:location (string) i18n
 - eui:requiresRSVP (boolean)
 - eui:heroImage (weakreference, picker[type='image']) < 'jmix:image'
